{
    auto_https off
    frankenphp
    order php_server before file_server
}

:80 {
    root * /app/public
    encode zstd gzip
    php_server
    file_server

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
