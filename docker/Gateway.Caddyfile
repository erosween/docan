{
    auto_https off
}

:80 {
    encode zstd gzip
    reverse_proxy {
        dynamic a {
            name app
            port 80
            refresh 5s
        }
        lb_policy round_robin
        health_uri /up
        health_interval 10s
        fail_duration 15s
        max_fails 3
    }
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
