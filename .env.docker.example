APP_PORT=8080
APP_URL=http://localhost:8080
APP_REPLICAS=4
QUEUE_REPLICAS=2
APP_MEMORY_LIMIT=768M
DOCAN_VERSION=latest

# Wajib diganti sebelum deployment publik.
DB_DATABASE=sakukasir
DB_USERNAME=sakukasir
DB_PASSWORD=ganti-dengan-password-yang-kuat

# Boleh kosong; container membuat dan menyimpannya di volume secara otomatis.
APP_KEY=

# true membuat akun demo kasir@outlet.test / password.
# Seeder hanya berjalan sekali dan menyimpan penanda di volume aplikasi.
# Untuk production, sebaiknya ubah false setelah instalasi awal selesai.
SEED_DATABASE=true

# Biarkan true agar update source otomatis menjalankan migration terbaru.
RUN_MIGRATIONS=true

# Gunakan true jika aplikasi dibuka melalui domain HTTPS.
SESSION_SECURE_COOKIE=false
LOG_LEVEL=warning

# Opsional untuk pengujian kapasitas.
LOADTEST_LOGIN_ID=SDM-001
LOADTEST_PASSWORD=password
LOADTEST_VUS=100
LOADTEST_DURATION=3m
